# Dev: gemini (default). Release: anthropic
PLG_LLM_PROVIDER=gemini

GEMINI_API_KEY=your-gemini-api-key-here
# PLG_GEMINI_BUSY_RETRIES=4
# PLG_GEMINI_BUSY_WAIT_S=8

# Only needed when PLG_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# PLG_CLAUDE_MODEL=claude-sonnet-4-6

# Your library — FL Mafia / Splice / kits (see organize_kit.py)
PLG_SAMPLES_DIR=c:\PLUG.FLP\PLG_Library

# Open FL Studio automatically after CREATE BEAT (true / false)
PLG_AUTO_OPEN_FL=true

# Beat quota (30 beats / 30-day subscription period)
# PLG_BEAT_LIMIT=30
# PLG_BEAT_PERIOD_DAYS=30
# PLG_SUBSCRIPTION_START=2026-06-22
# PLG_SKIP_BEAT_LIMIT=true

# Optional: FL Studio profile for manual_steps (copy user_profile.example.json -> user_profile.json)
