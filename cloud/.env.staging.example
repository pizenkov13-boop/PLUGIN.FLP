# Staging — copy to cloud/.env.staging (NEVER use prod keys here)

PLG_ENV=staging

SUPABASE_URL=https://YOUR_STAGING_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=staging-service-role-key
SUPABASE_JWT_SECRET=staging-jwt-secret

GEMINI_API_KEY=staging-or-shared-dev-key

PLG_CAPTCHA_PROVIDER=none
PLG_WAITLIST_MODE=false
PLG_INVITE_ONLY=false

# Optional staging Redis (separate Upstash instance)
# REDIS_URL=rediss://default:xxx@staging.upstash.io:6379

# Sentry
# SENTRY_DSN=https://xxx@o123.ingest.sentry.io/456
# SENTRY_TRACES_SAMPLE_RATE=0.2

PLG_ADMIN_SECRET=staging-admin-secret

# Test payment keys only
# YOOKASSA_SHOP_ID=test
# YOOKASSA_SECRET_KEY=test
