# Supabase (Dashboard → Settings → API)

SUPABASE_URL=https://YOUR_PROJECT.supabase.co

SUPABASE_SERVICE_KEY=your-service-role-key

SUPABASE_JWT_SECRET=your-jwt-secret



# LLM keys (server only — never ship to clients)

PLG_LLM_PROVIDER=gemini

GEMINI_API_KEY=

# ANTHROPIC_API_KEY=  # for premium plan



# Quota

PLG_BEAT_LIMIT=30

PLG_BEAT_PERIOD_DAYS=30

PLG_DAILY_BEAT_LIMIT=3

PLG_MAX_DEVICES=3

PLG_TRIAL_BEATS=3

PLG_GRACE_DAYS=3



# Geo pricing

PLG_PRICE_CIS_RUB=899

PLG_PRICE_INTL_USD_CENTS=1499

PLG_BILLING_RETURN_URL=https://pluginflp.app/billing/return



# CIS — ЮKassa (start here: 899 ₽/mo)

YOOKASSA_SHOP_ID=

YOOKASSA_SECRET_KEY=



# International — enable after ~200 paying users

# STRIPE_SECRET_KEY=

# STRIPE_WEBHOOK_SECRET=

# STRIPE_PRICE_ID_INTL=price_xxx

# PADDLE_API_KEY=

# PADDLE_WEBHOOK_SECRET=



# Client version gate

PLG_APP_VERSION=1.0.0

PLG_MIN_CLIENT_VERSION=1.0.0



# Kill switch

PLG_EST_COST_BASE_USD=0.03

PLG_EST_COST_PREMIUM_USD=0.10



# Local dev without Supabase auth (NEVER in production)

# PLG_CLOUD_DEV_BYPASS=true

# Phase 3 — Security
PLG_GEN_COOLDOWN_SEC=15
PLG_GEN_HOURLY_LIMIT=20
PLG_IP_HOURLY_LIMIT=100
PLG_IP_DAILY_GEN_ALERT=50
PLG_LLM_QUEUE_SLOTS=8
PLG_REQUIRE_DEVICE_BINDING=true
PLG_CAPTCHA_PROVIDER=none
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# PLG_ADMIN_SECRET=change-me

# Phase 4 — Infra
PLG_ENV=development
# REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# PLG_WAITLIST_MODE=false
# PLG_INVITE_ONLY=false

# Phase 5 — Legal
PLG_LEGAL_TERMS_VERSION=1.0
PLG_LEGAL_PRIVACY_VERSION=1.0
PLG_LEGAL_MIN_AGE=16
PLG_PROMPT_LOG_RETENTION_DAYS=90
PLG_PAYMENT_LOG_RETENTION_DAYS=730
PLG_DATA_REGION=eu
PLG_SUPPORT_EMAIL=support@pluginflp.app

# Phase 6 — Ops
PLG_SUPPORT_TELEGRAM=https://t.me/pluginflp_support
PLG_SUPPORT_UPDATES_URL=https://t.me/pluginflp_updates
PLG_SUPPORT_SLA_HOURS=24-48
PLG_STATUS_PAGE_URL=https://status.pluginflp.app
RESEND_API_KEY=
PLG_EMAIL_FROM=PLUGIN.FLP <noreply@pluginflp.app>
POSTHOG_API_KEY=
PLG_RELEASE_DOWNLOAD_URL=
PLG_RELEASE_NOTES=Bug fixes and improvements.
# PLG_RELEASE_SHA256=
# PLG_RELEASE_MANDATORY=false

